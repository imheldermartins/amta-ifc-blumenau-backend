# ── Backend Cub's — DEV (carregado por npm run dev / start:dev / migrate) ──

# OBRIGATÓRIO em dev. A regra de ambiente (core/env.ts) é fail-safe: NODE_ENV
# ausente conta como PRODUÇÃO, então sem esta linha o servidor recusa subir
# (segredo JWT e CORS_ORIGINS viram obrigatórios). É de propósito — um deploy
# que esquece a variável falha alto em vez de rodar com segredo de dev.
NODE_ENV=development

# Porta do express (socket.io pega carona na mesma porta)
PORT=3000

# CORS: lista separada por vírgulas. Vazio/ausente em DEV cai em
# http://localhost:5173; em PROD, falha no boot. O socket.io usa a MESMA config.
# Obs.: no caminho padrão de dev o CORS nem engaja — o front fala com /api na
# própria origem (:5173) e o proxy do Vite repassa. Só importa ao apontar
# direto para o backend via VITE_CUBS_API_URL.
# CORS_ORIGINS=http://localhost:5173

# Cookie de sessão: em dev vai sem `Secure` (http). Ligue COOKIE_SECURE=1 se
# servir o dev por https (ex.: túnel *.trycloudflare.com) — senão o navegador
# descarta o cookie e a sessão "some" a cada F5.
# COOKIE_SECURE=1

# JWT: sem definir, o jwt-service usa fallbacks de dev ("dev-access-secret") e
# avisa uma vez no boot. Em produção, ausente ou < 32 chars = erro no boot.
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=

# Rate limit (defaults no rate-limit.config.ts: 300 req/60s global; 20/15min no /auth)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=300
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=20

# TRUST_PROXY=1 só quando houver reverse proxy (nginx) na frente — em dev NÃO.

# ── rqlite (como o backend alcança o banco) ──
# Vazio = localhost (container dev publica 127.0.0.1:8000 -> 4001)
RQLITE_ADVERTISE_IP=
RQLITE_PORT=8000
