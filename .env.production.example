# ── Backend Cub's — PROD (template; copie para .env.production e preencha) ──
# Usado por `npm start` (prod fora do Docker). No Docker, o equivalente é
# docker/backend.prod.env (ver docker/backend.prod.env.example).

PORT=3000

# Atrás do nginx: obrigatório, senão o rate limit enxerga o IP do proxy
# para todo mundo (e conta todos os usuários como um só).
TRUST_PROXY=1

# Origens públicas do site, separadas por vírgulas. NUNCA deixe vazio em
# prod (vazio = "*").
CORS_ORIGINS=http://localhost

# Segredos do JWT — gere valores longos e aleatórios (ex.: openssl rand -hex 64).
JWT_ACCESS_SECRET=TROQUE_POR_UM_SEGREDO_LONGO
JWT_REFRESH_SECRET=TROQUE_POR_OUTRO_SEGREDO_LONGO

# Rate limit (descomente para sobrescrever os defaults)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=300
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=20

# ── rqlite ──
# Fora do Docker: IP/host da máquina do rqlite. Dentro do compose de prod,
# use o hostname do serviço (rqlite) e a porta interna 4001.
RQLITE_ADVERTISE_IP=
RQLITE_PORT=8000
