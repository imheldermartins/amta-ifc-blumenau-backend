# Envs do container do backend (copie para docker/backend.prod.env — o real
# fica fora do git). Espelha o .env.production.example da raiz, com o rqlite
# apontando para o hostname interno do compose.

PORT=3000

# nginx do frontend proxia /api e /socket.io — o backend precisa confiar no
# X-Forwarded-For para o rate limit ver o IP real do client.
TRUST_PROXY=1

# Origem pública do site (a MESMA que o browser mostra). Lista separada por
# vírgulas se houver mais de uma. NUNCA vazio em prod (vazio = "*").
CORS_ORIGINS=http://localhost

# Gere segredos longos e aleatórios (ex.: openssl rand -hex 64).
JWT_ACCESS_SECRET=TROQUE_POR_UM_SEGREDO_LONGO
JWT_REFRESH_SECRET=TROQUE_POR_OUTRO_SEGREDO_LONGO

# rqlite pela rede interna do compose (serviço "rqlite", porta interna 4001).
RQLITE_ADVERTISE_IP=rqlite
RQLITE_PORT=4001

# Rate limit (descomente para sobrescrever os defaults do rate-limit.config.ts)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=300
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=20
