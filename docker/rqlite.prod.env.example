# Envs do container do rqlite em PROD (copie para docker/rqlite.prod.env).
# Em prod o rqlite não publica porta — só o backend o alcança pela rede
# interna do compose, então não há RQLITE_ALLOWED_HOST aqui.

# ID único do nó no cluster Raft (1, 2, 3... se houver cluster).
NODE_ID=1

# Vazio = o container anuncia o próprio IP interno. Em cluster multi-máquina,
# coloque o IP roteável da máquina.
RQLITE_ADVERTISE_IP=

# Vazio = nó líder. Worker: IP_DO_LIDER:4002.
JOIN_NODE=

# Header Access-Control-Allow-Origin (valor ÚNICO — o padrão CORS não aceita
# lista). Em prod normalmente fica vazio: nenhum browser fala com o rqlite.
RQLITE_HTTP_ALLOW_ORIGIN=
